# OpenAI Secure MCP Tunnel runtime key.
# Create this in OpenAI Platform with Tunnels Read + Use permissions.
CONTROL_PLANE_API_KEY=

# Path to the downloaded OpenAI tunnel-client binary.
TUNNEL_CLIENT_BIN=/path/to/tunnel-client

# Local tunnel-client profile name.
# The example value is only a convention; create this profile locally or replace it.
TUNNEL_CLIENT_PROFILE=gpt-repo-local

# Local MCP server settings.
GPT_REPO_CONFIG=./config.local.json
PORT=8787
GPT_REPO_LOG_FORMAT=pretty

# Auth tokens (generated by npm run setup:config).
# GPT_REPO_ACCESS_TOKEN is the primary ****** checked on every MCP request.
# GPT_REPO_PUBLIC_PATH_TOKEN is an optional URL path prefix for guess-resistance.
GPT_REPO_ACCESS_TOKEN=
GPT_REPO_PUBLIC_PATH_TOKEN=
